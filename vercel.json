{
  "version": 2,
  "rewrites": [
    { "source": "/mcp", "destination": "/api/mcp" },
    { "source": "/api/mcp", "destination": "/api/mcp" },
    { "source": "/(.*)", "destination": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
